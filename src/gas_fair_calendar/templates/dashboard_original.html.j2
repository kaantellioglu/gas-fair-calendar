}
.btn-add-ev:hover { transform:translateY(-3px); box-shadow:0 8px 24px rgba(99,102,241,.45); }
.btn-add-ev:active { transform:translateY(0); }
.btn-add-ev .plus { font-size:18px; line-height:1; font-weight:400; }

