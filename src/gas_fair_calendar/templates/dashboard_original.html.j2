<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Gaz & LNG Fuarları 2026 — Küresel Takvim</title>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
<style>
:root {
  --bg:        #f0f4f8;
  --bg2:       #e4eaf2;
  --surface:   #ffffff;
  --surface2:  #f7f9fc;
  --border:    #dde3ec;
  --text:      #1a2540;
  --text-2:    #4a5568;
  --text-3:    #8898aa;
  --shadow:    0 2px 14px rgba(26,37,64,0.08);
  --shadow-lg: 0 12px 48px rgba(26,37,64,0.14);
  --c-lng:    #0ea5e9;
  --c-lpg:    #f97316;
  --c-dist:   #8b5cf6;
  --c-ng:     #10b981;
  --c-equip:  #eab308;
  --c-boiler: #ec4899;
  --c-gcc:    #f59e0b;
  --c-asia:   #06b6d4;
  --r-eu:     #6366f1;
  --r-gcc:    #d97706;
  --r-turkic: #059669;
  --r-asia:   #0891b2;
}
*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior:smooth; }
body { font-family:'Plus Jakarta Sans',sans-serif; background:var(--bg); color:var(--text); min-height:100vh; line-height:1.6; }
::-webkit-scrollbar { width:5px; height:5px; }
::-webkit-scrollbar-track { background:var(--bg2); }
::-webkit-scrollbar-thumb { background:#c0cbd8; border-radius:4px; }

/* BG blobs */
.blobs { position:fixed; inset:0; pointer-events:none; z-index:0; overflow:hidden; }
.blob { position:absolute; border-radius:50%; filter:blur(80px); opacity:.45; animation:blobFloat 20s ease-in-out infinite alternate; }
.blob-1 { width:600px; height:600px; top:-200px; right:-100px; background:radial-gradient(circle, #c7d2fe, #e0f2fe); animation-duration:18s; }
.blob-2 { width:400px; height:400px; bottom:-100px; left:-80px; background:radial-gradient(circle, #a7f3d0, #bfdbfe); animation-duration:24s; animation-delay:-8s; }
.blob-3 { width:300px; height:300px; top:40%; left:45%; background:radial-gradient(circle, #fde68a, #fce7f3); animation-duration:15s; animation-delay:-4s; opacity:.25; }
@keyframes blobFloat { from{transform:translate(0,0) scale(1);} to{transform:translate(-30px,25px) scale(1.07);} }

/* LAYOUT */
.wrap { position:relative; z-index:1; max-width:1440px; margin:0 auto; padding:0 28px 80px; }

/* HEADER */
header {
  padding:52px 0 40px;
  display:flex; justify-content:space-between; align-items:flex-start; flex-wrap:wrap; gap:28px;
  border-bottom:1px solid var(--border); margin-bottom:44px;
  animation:slideDown .6s cubic-bezier(.22,1,.36,1) both;
}
@keyframes slideDown { from{opacity:0;transform:translateY(-20px);} to{opacity:1;transform:translateY(0);} }

.badge-eyebrow {
  font-family:'JetBrains Mono',monospace; font-size:10px; font-weight:500;
  letter-spacing:2.5px; text-transform:uppercase;
  color:var(--r-eu); background:rgba(99,102,241,.1);
  display:inline-block; padding:4px 12px; border-radius:20px; margin-bottom:14px;
}
h1 { font-size:clamp(24px,4vw,46px); font-weight:800; letter-spacing:-1.5px; line-height:1.08; color:var(--text); margin-bottom:10px; }
h1 em { font-style:normal; color:var(--r-eu); }
.header-desc { font-size:14px; color:var(--text-2); max-width:500px; line-height:1.75; }
.pills { display:flex; flex-wrap:wrap; gap:7px; margin-top:18px; }
.pill {
  font-family:'JetBrains Mono',monospace; font-size:10px; font-weight:500;
  padding:4px 12px; border-radius:20px; border:1.5px solid; letter-spacing:.4px;
  transition:transform .15s, box-shadow .15s;
}
.pill:hover { transform:translateY(-2px); box-shadow:0 4px 12px rgba(0,0,0,.1); }

.stats-grid { display:flex; gap:14px; flex-wrap:wrap; align-self:flex-end; }
.stat-box {
  background:var(--surface); border:1px solid var(--border); border-radius:14px;
  padding:16px 22px; text-align:center; box-shadow:var(--shadow);
  transition:transform .2s; min-width:80px;
}
.stat-box:hover { transform:translateY(-4px); }
.stat-n {
  font-size:30px; font-weight:800; line-height:1;
  background:linear-gradient(135deg,var(--r-eu),var(--c-asia));
  -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;
}
.stat-l { font-family:'JetBrains Mono',monospace; font-size:9px; color:var(--text-3); letter-spacing:1px; text-transform:uppercase; margin-top:4px; }

/* TABS */
.tabs {
  display:flex; gap:3px; background:var(--surface);
  border:1px solid var(--border); border-radius:14px; padding:4px;
  margin-bottom:32px; width:fit-content; box-shadow:var(--shadow);
  animation:fadeUp .5s .15s both;
}
@keyframes fadeUp { from{opacity:0;transform:translateY(8px);} to{opacity:1;transform:translateY(0);} }
.tab {
  padding:9px 22px; border-radius:10px; font-size:13px; font-weight:600;
  cursor:pointer; border:none; background:transparent; color:var(--text-2);
  transition:all .2s cubic-bezier(.22,1,.36,1); white-space:nowrap;
}
.tab:hover { color:var(--text); background:var(--bg2); }
.tab.on { background:var(--text); color:#fff; box-shadow:0 2px 10px rgba(26,37,64,.2); }

/* PANELS */
.panel { display:none; }
.panel.on { display:block; animation:panelIn .3s cubic-bezier(.22,1,.36,1) both; }
@keyframes panelIn { from{opacity:0;transform:translateY(8px);} to{opacity:1;transform:translateY(0);} }

/* SECTION HEADING */
.sh {
  font-family:'JetBrains Mono',monospace; font-size:10px; font-weight:600;
  letter-spacing:2.5px; text-transform:uppercase; color:var(--text-3);
  margin-bottom:20px; display:flex; align-items:center; gap:10px;
}
.sh::after { content:''; flex:1; height:1px; background:var(--border); }

/* ══════════ CALENDAR ══════════ */
.cal { display:grid; grid-template-columns:repeat(auto-fill,minmax(310px,1fr)); gap:16px; }

.mcard {
  background:var(--surface); border:1px solid var(--border); border-radius:16px;
  overflow:hidden; box-shadow:var(--shadow);
  transition:transform .25s cubic-bezier(.22,1,.36,1), box-shadow .25s;
  animation:cardIn .45s cubic-bezier(.22,1,.36,1) both;
}
@keyframes cardIn { from{opacity:0;transform:scale(.96) translateY(10px);} to{opacity:1;transform:scale(1) translateY(0);} }
.mcard:hover { transform:translateY(-5px); box-shadow:var(--shadow-lg); }

.mcard-head {
  padding:13px 18px; background:var(--surface2); border-bottom:1px solid var(--border);
  display:flex; justify-content:space-between; align-items:center;
}
.mcard-name { font-size:13px; font-weight:700; }
.mcard-cnt {
  font-family:'JetBrains Mono',monospace; font-size:10px; color:var(--text-3);
  background:var(--bg); border:1px solid var(--border); border-radius:10px; padding:2px 8px;
}
.evlist { padding:10px; display:flex; flex-direction:column; gap:7px; }

.evc {
  padding:11px 13px; border-radius:10px; border-left:3px solid;
  background:var(--surface2); cursor:pointer;
  transition:background .15s, transform .18s cubic-bezier(.22,1,.36,1), box-shadow .18s;
  position:relative;
}
.evc:hover { background:#fff; transform:translateX(4px); box-shadow:0 3px 14px rgba(0,0,0,.07); }
.evc-date { font-family:'JetBrains Mono',monospace; font-size:10px; color:var(--text-3); margin-bottom:3px; }
.evc-name { font-size:12px; font-weight:700; color:var(--text); margin-bottom:4px; line-height:1.35; }
.evc-loc { display:flex; align-items:center; gap:5px; font-size:11px; color:var(--text-2); }
.evc-tag {
  display:inline-block; margin-top:5px;
  font-family:'JetBrains Mono',monospace; font-size:9px; font-weight:600;
  padding:2px 7px; border-radius:5px; text-transform:uppercase; letter-spacing:.4px;
}

/* ══════════ TIMELINE ══════════ */
.tl-wrap {
  background:var(--surface); border:1px solid var(--border); border-radius:20px;
  padding:28px; box-shadow:var(--shadow);
}
.tl-legend { display:flex; flex-wrap:wrap; gap:12px; margin-bottom:20px; }
.tl-leg-item { display:flex; align-items:center; gap:6px; font-size:11px; font-weight:600; cursor:pointer; }
.tl-leg-dot { width:10px; height:10px; border-radius:3px; }
.tl-scroll { overflow-x:auto; padding-bottom:6px; }
.tl-inner { min-width:920px; }

.tl-months {
  display:flex; border-bottom:2px solid var(--border); margin-bottom:0;
}
.tl-m {
  flex:1; text-align:center; padding:8px 0;
  font-family:'JetBrains Mono',monospace; font-size:10px; font-weight:600;
  color:var(--text-3); letter-spacing:1px; text-transform:uppercase;
  border-right:1px solid var(--border);
}
.tl-m:last-child { border-right:none; }

.tl-body { position:relative; min-width:920px; padding-top:14px; padding-bottom:10px; }

.tl-gl { position:absolute; inset:0; display:flex; pointer-events:none; }
.tl-gl-line { flex:1; border-right:1px dashed rgba(0,0,0,.05); }

.tl-bar {
  position:absolute; height:32px; border-radius:8px;
  display:flex; align-items:center; padding:0 10px;
  font-size:10px; font-weight:700;
  white-space:nowrap; overflow:hidden; text-overflow:ellipsis;
  cursor:pointer; border-left:3px solid;
  transition:transform .15s, box-shadow .15s, filter .15s;
}
.tl-bar:hover { transform:scaleY(1.1) translateY(-2px); box-shadow:0 6px 20px rgba(0,0,0,.12); z-index:10; filter:brightness(1.04); }

/* ══════════ TABLE ══════════ */
.tbl-toolbar {
  display:flex; gap:8px; flex-wrap:wrap; align-items:center; margin-bottom:14px;
}
.tbl-lbl { font-size:12px; font-weight:700; color:var(--text-2); }

.fbtn {
  font-family:'JetBrains Mono',monospace; font-size:10px; font-weight:600;
  padding:6px 14px; border-radius:20px; border:1.5px solid var(--border);
  background:var(--surface); color:var(--text-2); cursor:pointer;
  transition:all .18s cubic-bezier(.22,1,.36,1);
}
.fbtn:hover { transform:translateY(-1px); box-shadow:0 3px 10px rgba(0,0,0,.08); }
.fbtn.on { color:#fff; border-color:transparent; box-shadow:0 3px 12px rgba(0,0,0,.15); }
.fbtn[data-r="all"].on  { background:var(--text); }
.fbtn[data-r="eu"].on   { background:var(--r-eu); }
.fbtn[data-r="gcc"].on  { background:var(--r-gcc); }
.fbtn[data-r="turkic"].on { background:var(--r-turkic); }
.fbtn[data-r="asia"].on { background:var(--r-asia); }

.srch {
  margin-left:auto; display:flex; align-items:center; gap:7px;
  background:var(--surface); border:1.5px solid var(--border); border-radius:10px;
  padding:7px 14px; transition:border-color .2s;
}
.srch:focus-within { border-color:var(--r-eu); }
.srch input { border:none; outline:none; background:transparent; font-family:'Plus Jakarta Sans',sans-serif; font-size:13px; color:var(--text); width:190px; }
.srch input::placeholder { color:var(--text-3); }

.cnt-badge { font-family:'JetBrains Mono',monospace; font-size:11px; color:var(--text-3); padding:4px 10px; background:var(--bg2); border-radius:8px; border:1px solid var(--border); }

.tbl-outer { background:var(--surface); border:1px solid var(--border); border-radius:16px; overflow:hidden; box-shadow:var(--shadow); overflow-x:auto; }
.tbl { width:100%; border-collapse:collapse; font-size:13px; }
.tbl th {
  font-family:'JetBrains Mono',monospace; font-size:9px; font-weight:700;
  letter-spacing:1.5px; text-transform:uppercase; color:var(--text-3);
  padding:12px 15px; background:var(--surface2); border-bottom:1px solid var(--border);
  text-align:left; white-space:nowrap; cursor:pointer; user-select:none;
}
.tbl th:hover { color:var(--text-2); }
.tbl th .si { margin-left:3px; opacity:.35; transition:opacity .15s; }
.tbl th.sorted .si { opacity:1; color:var(--r-eu); }
.tbl td { padding:12px 15px; border-bottom:1px solid var(--border); vertical-align:middle; transition:background .1s; }
.tbl tr:last-child td { border-bottom:none; }
.tbl tr:hover td { background:var(--surface2); }
.tbl tr.hide { display:none; }
.tbl tr { animation:rowIn .25s ease both; }
@keyframes rowIn { from{opacity:0;transform:translateX(-4px);} to{opacity:1;transform:translateX(0);} }

.t-name { font-weight:700; color:var(--text); }
.t-date { font-family:'JetBrains Mono',monospace; font-size:11px; color:var(--text-2); white-space:nowrap; }
.t-loc { font-size:12px; color:var(--text-2); }
.t-loc small { display:block; font-size:10px; color:var(--text-3); }
.t-reg { font-family:'JetBrains Mono',monospace; font-size:9px; font-weight:600; padding:3px 8px; border-radius:5px; text-transform:uppercase; white-space:nowrap; }
.rg-eu     { background:rgba(99,102,241,.1); color:#4338ca; }
.rg-gcc    { background:rgba(217,119,6,.1);  color:#92400e; }
.rg-turkic { background:rgba(5,150,105,.1);  color:#065f46; }
.rg-asia   { background:rgba(8,145,178,.1);  color:#0e7490; }
.t-cat span { font-family:'JetBrains Mono',monospace; font-size:9px; font-weight:600; padding:3px 7px; border-radius:5px; text-transform:uppercase; }
.t-org { font-size:11px; color:var(--text-2); }
.t-org small { font-family:'JetBrains Mono',monospace; font-size:10px; color:var(--text-3); }
.t-tck { font-size:11px; color:var(--text-2); max-width:200px; }
.t-lnk a {
  font-family:'JetBrains Mono',monospace; font-size:11px; font-weight:600;
  color:var(--r-eu); text-decoration:none; padding:4px 10px;
  border-radius:6px; background:rgba(99,102,241,.08); transition:background .15s;
}
.t-lnk a:hover { background:rgba(99,102,241,.16); }
.no-res { display:none; text-align:center; padding:48px; color:var(--text-3); font-size:14px; }

/* NOTE */
.note { margin-top:16px; background:#fffbeb; border:1px solid #fde68a; border-radius:10px; padding:13px 16px; font-size:12px; color:#78350f; line-height:1.7; }
.note strong { color:#92400e; }

/* MODAL */
.moverlay {
  display:none; position:fixed; inset:0;
  background:rgba(15,23,42,.5); backdrop-filter:blur(7px);
  z-index:200; align-items:center; justify-content:center; padding:24px;
}
.moverlay.on { display:flex; }
.mbox {
  background:var(--surface); border:1px solid var(--border); border-radius:20px;
  max-width:640px; width:100%; box-shadow:var(--shadow-lg); overflow:hidden;
  animation:mIn .28s cubic-bezier(.22,1,.36,1);
}
@keyframes mIn { from{opacity:0;transform:scale(.93) translateY(18px);} to{opacity:1;transform:scale(1) translateY(0);} }
.mbox-accent { height:5px; }
.mbody { padding:28px 30px 30px; }
.mclose { float:right; background:none; border:none; cursor:pointer; color:var(--text-3); font-size:18px; padding:4px 7px; border-radius:6px; transition:background .15s, color .15s; line-height:1; }
.mclose:hover { background:var(--bg2); color:var(--text); }
.meye { font-family:'JetBrains Mono',monospace; font-size:10px; font-weight:600; letter-spacing:1.5px; text-transform:uppercase; display:inline-block; padding:3px 9px; border-radius:6px; margin-bottom:10px; }
.mtitle { font-size:21px; font-weight:800; color:var(--text); line-height:1.2; margin-bottom:6px; letter-spacing:-.3px; }
.mloc { font-size:13px; color:var(--text-2); display:flex; align-items:center; gap:6px; margin-bottom:18px; flex-wrap:wrap; }
.mhr { height:1px; background:var(--border); margin:14px 0; }
.mgrid { display:grid; grid-template-columns:1fr 1fr; gap:14px; margin-bottom:14px; }
.mf label { font-family:'JetBrains Mono',monospace; font-size:9px; color:var(--text-3); letter-spacing:1.5px; text-transform:uppercase; display:block; margin-bottom:3px; }
.mf span { font-size:13px; font-weight:600; color:var(--text); }
.mdesc { font-size:13px; color:var(--text-2); line-height:1.78; margin-bottom:18px; }
.macts { display:flex; flex-wrap:wrap; gap:9px; }
.btn-p { display:inline-flex; align-items:center; gap:6px; padding:9px 18px; border-radius:10px; background:var(--text); color:#fff; font-size:12px; font-weight:700; text-decoration:none; transition:opacity .15s, transform .15s; }
.btn-p:hover { opacity:.85; transform:translateY(-1px); }
.btn-s { display:inline-flex; align-items:center; gap:6px; padding:9px 16px; border-radius:10px; background:var(--surface2); color:var(--text-2); font-size:12px; font-weight:600; text-decoration:none; border:1px solid var(--border); transition:background .15s; }
.btn-t { display:inline-flex; align-items:center; gap:6px; padding:9px 14px; border-radius:10px; background:var(--bg2); color:var(--text-2); font-size:12px; font-weight:600; border:1px solid var(--border); }

/* DELETE BUTTON */
.btn-del {
  display:inline-flex; align-items:center; gap:6px;
  padding:9px 16px; border-radius:10px;
  background:rgba(239,68,68,.08); color:#dc2626;
  font-size:12px; font-weight:700;
  border:1.5px solid rgba(239,68,68,.2); cursor:pointer;
  transition:all .18s cubic-bezier(.22,1,.36,1);
  margin-left:auto;
}
.btn-del:hover { background:rgba(239,68,68,.14); border-color:rgba(239,68,68,.4); transform:translateY(-1px); }

/* CONFIRM + PASSWORD OVERLAYS */
.cpoverlay {
  display:none; position:fixed; inset:0;
  background:rgba(15,23,42,.65); backdrop-filter:blur(9px);
  z-index:500; align-items:center; justify-content:center; padding:24px;
}
.cpoverlay.on { display:flex; }
.cpbox {
  background:var(--surface); border:1px solid var(--border);
  border-radius:20px; max-width:420px; width:100%;
  box-shadow:0 20px 60px rgba(26,37,64,.2);
  animation:mIn .25s cubic-bezier(.22,1,.36,1); overflow:hidden;
}
.cpbox-icon {
  width:52px; height:52px; border-radius:14px;
  display:flex; align-items:center; justify-content:center;
  font-size:26px; margin:28px auto 14px;
}
.cpbox-icon.warn { background:rgba(239,68,68,.1); }
.cpbox-icon.lock { background:rgba(99,102,241,.1); }
.cpbox-title {
  font-size:18px; font-weight:800; color:var(--text);
  text-align:center; padding:0 26px; line-height:1.3; margin-bottom:8px;
}
.cpbox-sub {
  font-size:13px; color:var(--text-2); text-align:center;
  padding:0 26px; line-height:1.65; margin-bottom:22px;
}
.cpbox-sub strong { color:var(--text); }
.cpbox-hr { height:1px; background:var(--border); }
.cpbox-actions { display:flex; gap:10px; padding:18px 22px; }
.cpbtn-no {
  flex:1; padding:11px; border-radius:10px;
  border:1.5px solid var(--border); background:var(--surface2);
  color:var(--text-2); font-size:13px; font-weight:600;
  cursor:pointer; transition:background .15s;
}
.cpbtn-no:hover { background:var(--bg2); }
.cpbtn-yes {
  flex:1; padding:11px; border-radius:10px;
  border:none; background:linear-gradient(135deg,#dc2626,#ef4444);
  color:#fff; font-size:13px; font-weight:700;
  cursor:pointer; box-shadow:0 3px 12px rgba(220,38,38,.3);
  transition:opacity .15s, transform .15s;
}
.cpbtn-yes:hover { opacity:.88; transform:translateY(-1px); }
/* password */
.pw-wrap { padding:0 22px 4px; }
.pw-field {
  display:flex; align-items:center;
  border:1.5px solid var(--border); border-radius:10px;
  overflow:hidden; background:var(--surface2);
  transition:border-color .2s, box-shadow .2s;
}
.pw-field:focus-within { border-color:#6366f1; box-shadow:0 0 0 3px rgba(99,102,241,.12); background:#fff; }
.pw-field input {
  flex:1; border:none; outline:none; background:transparent;
  padding:11px 13px; font-family:'Plus Jakarta Sans',sans-serif;
  font-size:14px; color:var(--text); letter-spacing:.5px;
}
.pw-toggle { padding:0 12px; border:none; background:transparent; color:var(--text-3); cursor:pointer; font-size:16px; transition:color .15s; }
.pw-toggle:hover { color:var(--text); }
.pw-err { font-size:12px; color:#dc2626; margin-top:6px; padding:0 2px; display:none; animation:shakeX .32s ease; }
@keyframes shakeX { 0%,100%{transform:translateX(0)} 20%,60%{transform:translateX(-6px)} 40%,80%{transform:translateX(6px)} }
.pw-submit {
  display:block; width:calc(100% - 44px); margin:14px 22px 22px;
  padding:12px; border-radius:10px; border:none;
  background:linear-gradient(135deg,#6366f1,#818cf8);
  color:#fff; font-size:13px; font-weight:700;
  cursor:pointer; box-shadow:0 3px 12px rgba(99,102,241,.3);
  transition:opacity .15s, transform .15s;
}
.pw-submit:hover { opacity:.9; transform:translateY(-1px); }

/* Calendar add button */
.btn-cal {
  display:inline-flex; align-items:center; gap:7px;
  padding:9px 18px; border-radius:10px;
  background:linear-gradient(135deg,#0052d4,#4364f7,#6fb1fc);
  color:#fff; font-size:12px; font-weight:700;
  border:none; cursor:pointer;
  transition:opacity .15s, transform .15s, box-shadow .15s;
  box-shadow:0 2px 10px rgba(67,100,247,.3);
  position:relative; overflow:hidden;
}
.btn-cal::after {
  content:''; position:absolute; inset:0;
  background:linear-gradient(135deg,rgba(255,255,255,.15),transparent);
}
.btn-cal:hover { opacity:.9; transform:translateY(-2px); box-shadow:0 6px 20px rgba(67,100,247,.4); }
.btn-cal:active { transform:translateY(0); }
.btn-cal .cal-icon { font-size:15px; }


/* UX improvements */
.livebar{display:flex;flex-wrap:wrap;gap:10px;margin:-10px 0 24px;animation:fadeUp .55s .2s both}
.live-pill{display:inline-flex;align-items:center;gap:8px;padding:8px 12px;border-radius:999px;background:var(--surface);border:1px solid var(--border);box-shadow:var(--shadow);font-size:12px;color:var(--text-2)}
.live-pill span{color:#10b981;font-size:10px}
.status-chip,.conf-chip,.src-chip{display:inline-flex;align-items:center;gap:6px;font-family:'JetBrains Mono',monospace;font-size:9px;font-weight:700;padding:3px 7px;border-radius:999px;text-transform:uppercase;letter-spacing:.4px;border:1px solid transparent}
.status-confirmed{background:rgba(16,185,129,.1);color:#047857;border-color:rgba(16,185,129,.22)}
.status-needs_review{background:rgba(245,158,11,.12);color:#b45309;border-color:rgba(245,158,11,.25)}
.status-candidate{background:rgba(99,102,241,.10);color:#4338ca;border-color:rgba(99,102,241,.22)}
.status-cancelled,.status-deprecated{background:rgba(239,68,68,.1);color:#b91c1c;border-color:rgba(239,68,68,.25)}
.conf-chip{background:rgba(26,37,64,.06);color:var(--text)}
.src-chip{background:rgba(6,182,212,.08);color:#0e7490}
.evc-top{display:flex;justify-content:space-between;gap:8px;align-items:flex-start;margin-bottom:3px}
.evc-meta{display:flex;gap:6px;flex-wrap:wrap;margin-top:6px}
.m-ver{display:flex;flex-wrap:wrap;gap:8px;margin:0 0 14px}
.tbl-toolbar{row-gap:10px}
@media(max-width:900px){.livebar{margin-top:4px}.srch{margin-left:0;width:100%}.srch input{width:100%}}

@media(max-width:640px) {
  .mgrid { grid-template-columns:1fr; }
  .stats-grid { display:none; }
  h1 { letter-spacing:-.5px; }
}

/* ── ADD EVENT BUTTON ── */
.btn-add-ev {
  display:inline-flex; align-items:center; gap:8px;
  padding:11px 22px; border-radius:12px;
  background:linear-gradient(135deg,#6366f1,#818cf8);
  color:#fff; font-size:13px; font-weight:700;
  border:none; cursor:pointer;
