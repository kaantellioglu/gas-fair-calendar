<script>
/* ═══════════ DATA ═══════════ */
const EV = {{ events_json | safe }};
const BUILD_META = {{ build_meta_json | safe }};

/* ═══════════ CONFIG ═══════════ */
const MONTHS = ['Ocak','Şubat','Mart','Nisan','Mayıs','Haziran','Temmuz','Ağustos','Eylül','Ekim','Kasım','Aralık'];
const MCUM   = [0,31,59,90,120,151,181,212,243,273,304,334,366];
const MDAYS  = [31,28,31,30,31,30,31,31,30,31,30,31];

const CAT = {
  lng:   {bg:'rgba(14,165,233,.1)', color:'#0369a1'},
  lpg:   {bg:'rgba(249,115,22,.1)', color:'#9a3412'},
  dist:  {bg:'rgba(139,92,246,.1)', color:'#6d28d9'},
  ng:    {bg:'rgba(16,185,129,.1)', color:'#065f46'},
  equip: {bg:'rgba(234,179,8,.1)',  color:'#92400e'},
  boiler:{bg:'rgba(236,72,153,.1)', color:'#9d174d'},
  gcc:   {bg:'rgba(245,158,11,.15)',color:'#78350f'},
  asia:  {bg:'rgba(6,182,212,.12)', color:'#0e7490'}
};
const REG = {
  eu:    {label:'Avrupa',              cls:'rg-eu'},
  gcc:   {label:'GCC / Orta Doğu',    cls:'rg-gcc'},
  turkic:{label:'Türki Cumhuriyetler', cls:'rg-turkic'},
  asia:  {label:'Asya-Pasifik',        cls:'rg-asia'}
};

function getMonth(d) { for(let i=0;i<12;i++) if(d>MCUM[i]&&d<=MCUM[i+1]) return i; return 0; }

/* ═══════════ TABS ═══════════ */
function switchTab(id, btn) {
  document.querySelectorAll('.tab').forEach(b=>b.classList.remove('on'));
  document.querySelectorAll('.panel').forEach(p=>p.classList.remove('on'));
  btn.classList.add('on');
  document.getElementById('panel-'+id).classList.add('on');
}

/* ═══════════ CALENDAR ═══════════ */
function buildCal() {
  const grid = document.getElementById('cal-grid');
  const bm = {};
  EV.forEach(e => { const m=getMonth(e.s); (bm[m]||(bm[m]=[])).push(e); });
  Object.keys(bm).sort((a,b)=>+a-+b).forEach((mi,i) => {
    const evts = bm[mi];
    const card = document.createElement('div');
    card.className='mcard'; card.style.animationDelay=(i*.05)+'s';
    card.innerHTML=`
      <div class="mcard-head">
        <span class="mcard-name">${MONTHS[mi]} 2026</span>
        <span class="mcard-cnt">${evts.length} etkinlik</span>
      </div>
      <div class="evlist">
        ${evts.map(e=>`
          <div class="evc ${e.type}" onclick="openM(${e.id})">
            <div class="evc-date">${e.dates} 2026</div>
            <div class="evc-top"><div class="evc-name">${e.name}</div><span class="status-chip status-${e.status||'confirmed'}">${statusLabel(e.status)}</span></div>
            <div class="evc-loc"><span>${e.flag}</span><span>${e.city}, ${e.country}</span></div>
            <div class="evc-meta"><span class="evc-tag ${e.type}">${e.tag}</span><span class="conf-chip">Skor ${(e.confidence*100).toFixed(0)}%</span></div>
          </div>`).join('')}
      </div>`;
    grid.appendChild(card);
  });
}

/* ═══════════ TIMELINE ═══════════ */
function buildTL() {
  // Legend
  const leg = document.getElementById('tl-legend');
  [...new Set(EV.map(e=>e.type))].forEach(t => {
    const c = CAT[t];
    const el = document.createElement('div');
    el.className = 'tl-leg-item';
    el.innerHTML = `<div class="tl-leg-dot" style="background:${c.color}"></div><span style="color:${c.color}">${t.toUpperCase()}</span>`;
    leg.appendChild(el);
  });

  // Month headers
  const mhdr = document.getElementById('tl-months');
  MONTHS.forEach(m => {
    const el=document.createElement('div');
    el.className='tl-m'; el.textContent=m.slice(0,3).toUpperCase();
    mhdr.appendChild(el);
  });

  // Gridlines
  const gl = document.getElementById('tl-gl');
  for(let i=0;i<12;i++) { const l=document.createElement('div'); l.className='tl-gl-line'; gl.appendChild(l); }

  // Bars
  const body = document.getElementById('tl-body');
  const TOTAL=366, RH=32, GAP=8;
  const rows = [];
  const sorted = [...EV].sort((a,b)=>a.s-b.s);
  sorted.forEach(e => {
    const lp = ((e.s-1)/TOTAL*100).toFixed(3);
    const wp = (Math.max(2.5,e.e-e.s+1)/TOTAL*100).toFixed(3);
    let row=0;
    while(rows[row]!==undefined && rows[row]>e.s-1) row++;
    rows[row]=e.e;
    const c=CAT[e.type];
    const bar=document.createElement('div');
    bar.className=`tl-bar ${e.type}`;
    bar.style.cssText=`left:${lp}%;width:${wp}%;top:${row*(RH+GAP)}px;background:${c.bg};color:${c.color};border-left-color:${c.color}`;
    bar.textContent=e.shortName;
    bar.title=`${e.name} | ${e.dates} | ${e.city}, ${e.country}`;
    bar.onclick=()=>openM(e.id);
    body.appendChild(bar);
  });
  body.style.minHeight=(rows.length*(RH+GAP)+20)+'px';
}

/* ═══════════ TABLE ═══════════ */
function buildTbl() {
  const tbody = document.getElementById('tbl-body');
  const sorted = [...EV].sort((a,b)=>a.s-b.s);
  sorted.forEach(e => {
    const r=REG[e.region]||REG.eu;
    const c=CAT[e.type];
    const tr=document.createElement('tr');
    tr.dataset.region=e.region;
    tr.dataset.q=`${e.name} ${e.city} ${e.country} ${e.tag} ${e.org}`.toLowerCase();
    tr.dataset.s=e.s;
    tr.dataset.status=e.status||'confirmed';
    tr.innerHTML=`
      <td class="t-name">${e.flag} ${e.name}<div style="margin-top:6px;display:flex;gap:6px;flex-wrap:wrap"><span class="status-chip status-${e.status||'confirmed'}">${statusLabel(e.status)}</span><span class="src-chip">${sourceLabel(e.source_type)}</span></div></td>
      <td class="t-date">${e.dates} 2026</td>
      <td class="t-loc">${e.city}<small>${e.country}</small></td>
      <td><span class="t-reg ${r.cls}">${r.label}</span></td>
      <td class="t-cat"><span style="background:${c.bg};color:${c.color}">${e.tag}</span></td>
      <td class="t-org">${e.org}<small>${e.contact}</small></td>
      <td class="t-tck">${e.ticket}</td>
      <td class="t-lnk"><a href="${e.url}" target="_blank" rel="noopener">↗ Site</a></td>`;
    tbody.appendChild(tr);
  });
}

/* ═══════════ FILTER/SEARCH ═══════════ */
let aReg='all', aQ='';
function filterTbl(r,btn) {
  document.querySelectorAll('.fbtn').forEach(b=>b.classList.remove('on'));
  btn.classList.add('on'); aReg=r; apply();
}
function srchTbl(v) { aQ=v.trim().toLowerCase(); apply(); }
function apply() {
  const rows=[...document.querySelectorAll('#tbl-body tr')];
  let vis=0;
  rows.forEach(tr => {
    const ok=(aReg==='all'||tr.dataset.region===aReg) && (aStatus==='all'||tr.dataset.status===aStatus) && (!aQ||tr.dataset.q.includes(aQ));
    tr.classList.toggle('hide',!ok);
    if(ok) vis++;
  });
  document.getElementById('cnt').textContent=vis+' etkinlik';
  document.getElementById('no-res').style.display=vis===0?'block':'none';
}

/* ═══════════ SORT ═══════════ */
let sortSt={col:null,asc:true};
function sortTbl(col) {
  const tbody=document.getElementById('tbl-body');
  const rows=[...tbody.querySelectorAll('tr')];
  sortSt.asc=sortSt.col===col?!sortSt.asc:true; sortSt.col=col;
  const val=tr=>col==='date'?+tr.dataset.s:col==='name'?tr.cells[0].textContent.trim():tr.cells[2].textContent.trim();
  rows.sort((a,b)=>{const av=val(a),bv=val(b),c=typeof av==='number'?av-bv:av.localeCompare(bv,'tr');return sortSt.asc?c:-c;});
  rows.forEach(r=>tbody.appendChild(r));
  document.querySelectorAll('.tbl th').forEach(t=>t.classList.remove('sorted'));
}

/* ═══════════ ICS / OUTLOOK CALENDAR ═══════════ */

// Day-of-year start days → real calendar date mapping for 2026
// Pre-computed: startDay (1-indexed) → {y,m,d}
function dayToDate(dayOfYear) {
  const MCUM = [0,31,59,90,120,151,181,212,243,273,304,334];
  const MDAYS = [31,28,31,30,31,30,31,31,30,31,30,31];
  let month = 0;
  for(let i=11; i>=0; i--) { if(dayOfYear > MCUM[i]) { month=i; break; } }
  const day = dayOfYear - MCUM[month];
  return { y:2026, m:month+1, d:day };
}

function pad(n) { return String(n).padStart(2,'0'); }

function toICSDate(dayOfYear) {
  const {y,m,d} = dayToDate(dayOfYear);
  return `${y}${pad(m)}${pad(d)}`;
}

function escICS(str) {
  return str.replace(/\\/g,'\\\\').replace(/;/g,'\\;').replace(/,/g,'\\,').replace(/\n/g,'\\n');
}

function generateICS(ev) {
  const dtStart  = toICSDate(ev.s);
  // End = day after last day (ICS DTEND is exclusive for all-day events)
  const dtEnd    = toICSDate(ev.e + 1);
  const uid      = `fuar2026-${ev.id}-${Date.now()}@gazfuarlari`;
  const now      = new Date().toISOString().replace(/[-:]/g,'').split('.')[0]+'Z';
  const summary  = escICS(ev.name);
  const location = escICS(`${ev.venue}, ${ev.city}, ${ev.country}`);
  const desc     = escICS(`${ev.desc}\n\nOrganizatör: ${ev.org}\nİletişim: ${ev.contact}\nBilet: ${ev.ticket}\nWeb: ${ev.url}`);
  const url      = ev.url;

  const ics = [
    'BEGIN:VCALENDAR',
    'VERSION:2.0',
    'PRODID:-//Gaz Fuarlari 2026//TR',
    'CALSCALE:GREGORIAN',
    'METHOD:PUBLISH',
    'X-WR-CALNAME:Gaz Fuarları 2026',
    'X-WR-TIMEZONE:Europe/Istanbul',
    'BEGIN:VEVENT',
    `UID:${uid}`,
    `DTSTAMP:${now}`,
    `DTSTART;VALUE=DATE:${dtStart}`,
    `DTEND;VALUE=DATE:${dtEnd}`,
    `SUMMARY:${summary}`,
    `LOCATION:${location}`,
    `DESCRIPTION:${desc}`,
    `URL:${url}`,
    'TRANSP:TRANSPARENT',
    'STATUS:CONFIRMED',
    'END:VEVENT',
    'END:VCALENDAR'
  ].join('\r\n');

  return ics;
}

function addToCalendar(id) {
  const e = EV.find(x => x.id === id);
  if(!e) return;

  const ics  = generateICS(e);
  const blob = new Blob([ics], { type:'text/calendar;charset=utf-8' });
  const url  = URL.createObjectURL(blob);

  // Safe filename
  const fname = e.name.replace(/[^a-z0-9]/gi,'_').substring(0,50) + '.ics';

  const a = document.createElement('a');
  a.href = url; a.download = fname;
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  setTimeout(() => URL.revokeObjectURL(url), 1000);

  // Visual feedback on button
  const btn = document.getElementById('btn-cal-' + id);
  if(btn) {
    btn.textContent = '✅ İndirildi!';
    btn.style.background = 'linear-gradient(135deg,#059669,#10b981)';
    setTimeout(() => {
      btn.innerHTML = '<span class="cal-icon">📅</span> Takvime Ekle (Outlook)';
      btn.style.background = '';
    }, 2500);
  }
}

/* ═══════════ MODAL ═══════════ */
function openM(id) {
  const e=EV.find(x=>x.id===id); if(!e) return;
  const c=CAT[e.type], r=REG[e.region]||REG.eu;
  document.getElementById('m-acc').style.background=c.color;
  document.getElementById('m-eye').textContent=e.tag;
  document.getElementById('m-eye').style.cssText=`background:${c.bg};color:${c.color}`;
  document.getElementById('m-title').textContent=e.name;
  document.getElementById('m-loc').innerHTML=`<span>${e.flag}</span> ${e.city}, ${e.country} &nbsp;·&nbsp; <span class="t-reg ${r.cls}">${r.label}</span>`;
  document.getElementById('m-dates').textContent=e.dates+' 2026';
  document.getElementById('m-org').textContent=e.org;
  document.getElementById('m-venue').textContent=e.venue;
  document.getElementById('m-scale').textContent=e.scale;
  document.querySelectorAll('.m-ver').forEach(el=>el.remove());
  document.getElementById('m-desc').textContent=e.desc;
  document.getElementById('m-desc').insertAdjacentHTML('afterend', `<div class="m-ver"><span class="status-chip status-${e.status||'confirmed'}">${statusLabel(e.status)}</span><span class="conf-chip">Güven ${(e.confidence*100).toFixed(0)}%</span><span class="src-chip">${sourceLabel(e.source_type)}</span><span class="src-chip">Son kontrol ${fmtDT(e.last_checked_at)}</span></div>`);
  document.getElementById('m-acts').innerHTML=`
    <a href="${e.url}" target="_blank" rel="noopener" class="btn-p">↗ Web Sitesi</a>
    <a href="mailto:${e.contact}" class="btn-s">✉ ${e.contact}</a>
    <span class="btn-t">🎟 ${e.ticket}</span>
    <button id="btn-cal-${e.id}" class="btn-cal" onclick="addToCalendar(${e.id})">
      <span class="cal-icon">📅</span> Takvime Ekle (Outlook)
    </button>
    <button class="btn-del" onclick="startDelete(${e.id})">🗑 Etkinliği Takvimden SİL</button>`;
  document.getElementById('mov').classList.add('on');
  document.body.style.overflow='hidden';
}
function closeM() { document.getElementById('mov').classList.remove('on'); document.body.style.overflow=''; }
function closeMOut(e) { if(e.target===document.getElementById('mov')) closeM(); }

