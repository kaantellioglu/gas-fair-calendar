}
.fg textarea { resize:vertical; min-height:80px; }
.fg select { cursor:pointer; }
.fg select:disabled { opacity:.45; cursor:not-allowed; background:var(--bg2); }
.city-hint { font-size:11px; color:var(--text-3); margin-top:3px; font-style:italic; }
.fg .hint { font-size:11px; color:var(--text-3); margin-top:2px; }

.ferr { font-size:12px; color:#e53e3e; display:none; }

.factions {
  display:flex; gap:10px; justify-content:flex-end; padding:0 26px 24px;
