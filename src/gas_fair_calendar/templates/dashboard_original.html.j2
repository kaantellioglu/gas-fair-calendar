  'Romanya':'🇷🇴','Sırbistan':'🇷🇸','Slovenya':'🇸🇮','Türkiye':'🇹🇷','Ukrayna':'🇺🇦',
  'Yunanistan':'🇬🇷','BAE':'🇦🇪','Bahreyn':'🇧🇭','Irak':'🇮🇶','İran':'🇮🇷',
  'Katar':'🇶🇦','Kuveyt':'🇰🇼','Mısır':'🇪🇬','Suudi Arabistan':'🇸🇦','Umman':'🇴🇲',
  'Azerbaycan':'🇦🇿','Kazakistan':'🇰🇿','Kırgızistan':'🇰🇬','Özbekistan':'🇺🇿',
  'Tacikistan':'🇹🇯','Türkmenistan':'🇹🇲','Avustralya':'🇦🇺','Çin':'🇨🇳',
  'Endonezya':'🇮🇩','Güney Kore':'🇰🇷','Hindistan':'🇮🇳','Japonya':'🇯🇵',
  'Malezya':'🇲🇾','Pakistan':'🇵🇰','Singapur':'🇸🇬','Tayland':'🇹🇭','Vietnam':'🇻🇳',
};

function onCountryChange() {
  const sel  = document.getElementById('f-country');
  const cityEl = document.getElementById('f-city');
  const hint   = document.getElementById('city-hint');
  const val    = sel.value; // "Ülke|code|region"

  if(!val) {
    cityEl.innerHTML = '<option value="">— Önce ülke seçin —</option>';
    cityEl.disabled = true;
    hint.style.display = 'block';
    // Auto-detect region: leave as-is
    return;
  }

  const parts   = val.split('|');
  const country = parts[0];
  const region  = parts[2] || 'eu';

  // Auto-set region dropdown
  document.getElementById('f-region').value = region;

  // Populate city dropdown
  const cities = CITIES[country] || [];
  cityEl.innerHTML = `<option value="">— Şehir Seçin —</option>` +
    cities.map(c => `<option value="${c}">${c}</option>`).join('') +
    `<option value="__other__">Diğer / Yukarıda yok</option>`;
  cityEl.disabled = false;
  hint.style.display = 'none';

  // Clear city error
  document.getElementById('ferr-city').style.display = 'none';
}

/* ═══════════ ADD EVENT FORM ═══════════ */

function openAddForm() {
  document.getElementById('fov').classList.add('on');
  document.body.style.overflow = 'hidden';
  // reset errors
  document.querySelectorAll('.ferr').forEach(el => el.style.display='none');
  // reset country & city
  document.getElementById('f-country').value = '';
  const cityEl = document.getElementById('f-city');
  cityEl.innerHTML = '<option value="">— Önce ülke seçin —</option>';
  cityEl.disabled = true;
  document.getElementById('city-hint').style.display = 'block';
}
function closeAddForm() {
  document.getElementById('fov').classList.remove('on');
  document.body.style.overflow = '';
}
function closeAddOut(e) {
  if(e.target === document.getElementById('fov')) closeAddForm();
}

function dateToDay(dateStr) {
  // dateStr = "2026-MM-DD"
  const parts = dateStr.split('-');
  const m = parseInt(parts[1]) - 1; // 0-indexed month
  const d = parseInt(parts[2]);
  const MCUM = [0,31,59,90,120,151,181,212,243,273,304,334];
  return MCUM[m] + d;
}

function formatDisplayDates(startStr, endStr) {
  const MONTHS_SHORT = ['Oca','Şub','Mar','Nis','May','Haz','Tem','Ağu','Eyl','Eki','Kas','Ara'];
  const sp = startStr.split('-'), ep = endStr.split('-');
  const sm = parseInt(sp[1])-1, sd = parseInt(sp[2]);
  const em = parseInt(ep[1])-1, ed = parseInt(ep[2]);
  if(sm === em) return `${sd}–${ed} ${MONTHS_SHORT[sm]}`;
  return `${sd} ${MONTHS_SHORT[sm]} – ${ed} ${MONTHS_SHORT[em]}`;
}

function submitEvent() {
  let valid = true;

  const name      = document.getElementById('f-name').value.trim();
  const startStr  = document.getElementById('f-start').value;
  const endStr    = document.getElementById('f-end').value;
  const countryVal= document.getElementById('f-country').value; // "Ülke|code|region"
  const cityVal   = document.getElementById('f-city').value;

  // Validate name
  if(!name) {
    document.getElementById('ferr-name').style.display='block'; valid=false;
  } else { document.getElementById('ferr-name').style.display='none'; }

  // Validate dates
  if(!startStr || !endStr || endStr < startStr) {
    document.getElementById('ferr-date').style.display='block'; valid=false;
  } else { document.getElementById('ferr-date').style.display='none'; }

  // Validate country
  if(!countryVal) {
    document.getElementById('ferr-country').style.display='block'; valid=false;
  } else { document.getElementById('ferr-country').style.display='none'; }

  // Validate city
  if(!cityVal || cityVal === '__other__' && false) { /* __other__ is OK */ }
  if(!cityVal) {
    document.getElementById('ferr-city').style.display='block'; valid=false;
  } else { document.getElementById('ferr-city').style.display='none'; }

  if(!valid) return;

  // Parse country select value: "Ülke Adı|code|region"
  const parts   = countryVal.split('|');
  const country = parts[0];
  const region  = document.getElementById('f-region').value; // already auto-set by onCountryChange
  const city    = cityVal === '__other__' ? 'Diğer' : cityVal;

  const flag = FLAG_MAP[country] || '🏳';

  const type = document.getElementById('f-type').value;
  const tagMap = {
    lng:'LNG', lpg:'LPG', dist:'DAĞITIM', ng:'ENERJİ',
    equip:'EKİPMAN', boiler:'BOILER', gcc:'GCC-GAZ', asia:'ASYA-GAZ'
  };

  const newId     = Math.max(...EV.map(e=>e.id)) + 1;
  const sDay      = dateToDay(startStr);
  const eDay      = dateToDay(endStr);
  const dispDates = formatDisplayDates(startStr, endStr);

  const newEv = {
    id:        newId,
    name:      name,
    shortName: name.length > 28 ? name.substring(0,28)+'…' : name,
    dates:     dispDates,
    s:         sDay,
    e:         eDay,
    city:      city,
    country:   country,
    flag:      flag,
    region:    region,
    type:      type,
    tag:       tagMap[type] || type.toUpperCase(),
    org:       document.getElementById('f-org').value.trim()     || '—',
    venue:     document.getElementById('f-venue').value.trim()   || city + ', ' + country,
    scale:     document.getElementById('f-scale').value.trim()   || '—',
    desc:      document.getElementById('f-desc').value.trim()    || '—',
    contact:   document.getElementById('f-contact').value.trim() || '—',
    url:       document.getElementById('f-url').value.trim()     || '#',
    ticket:    document.getElementById('f-ticket').value.trim()  || 'Bilgi için web sitesine bakınız',
    isCustom:  true
  };

  EV.push(newEv);

  // Rebuild all three panels
  document.getElementById('cal-grid').innerHTML = '';
  document.getElementById('tl-months').innerHTML = '';
  document.getElementById('tl-body').innerHTML = '<div class="tl-gl" id="tl-gl"></div>';
  document.getElementById('tl-legend').innerHTML = '';
  document.getElementById('tbl-body').innerHTML = '';
  buildCal(); buildTL(); buildTbl(); refreshLiveBar(); refreshLiveBar();

  // Update stat counter
  document.getElementById('stat-ev').textContent = EV.length;

  // Reset text inputs
  ['f-name','f-venue','f-org','f-contact','f-url','f-ticket','f-desc','f-scale']
    .forEach(id => { document.getElementById(id).value = ''; });

  // Reset date fields
  document.getElementById('f-start').value = '2026-03-01';
  document.getElementById('f-end').value   = '2026-03-03';

  // Reset selects
  document.getElementById('f-country').value = '';
  const cityEl2 = document.getElementById('f-city');
  cityEl2.innerHTML = '<option value="">— Önce ülke seçin —</option>';
  cityEl2.disabled = true;
  document.getElementById('city-hint').style.display = 'block';
  document.getElementById('f-region').value = 'eu';
  document.getElementById('f-type').value   = 'lng';

  closeAddForm();
  showToast('✅ "' + (name.length>35 ? name.substring(0,35)+'…' : name) + '" başarıyla eklendi!');
}

function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 3200);
}

/* ═══════════ DELETE FLOW ═══════════ */
const DELETE_PW = 'Export2026';
let _deleteId   = null;

function startDelete(id) {
  _deleteId = id;
  const e = EV.find(x => x.id === id);
  if(!e) return;
  // Close detail modal
  closeM();
  // Show confirm overlay
  document.getElementById('del-ev-name').textContent = e.name;
  document.getElementById('del-confirm').classList.add('on');
  document.body.style.overflow = 'hidden';
}

function cancelDelete() {
  document.getElementById('del-confirm').classList.remove('on');
  document.body.style.overflow = '';
  // Reopen the detail modal
  if(_deleteId !== null) openM(_deleteId);
}

function proceedToPassword() {
  document.getElementById('del-confirm').classList.remove('on');
  // Reset pw field
  const inp = document.getElementById('pw-input');
  inp.value = '';
  inp.type  = 'password';
  document.getElementById('pw-eye').textContent = '👁';
  document.getElementById('pw-err').style.display = 'none';
  document.getElementById('del-password').classList.add('on');
  setTimeout(() => inp.focus(), 120);
}

function togglePw() {
  const inp = document.getElementById('pw-input');
  const eye = document.getElementById('pw-eye');
  if(inp.type === 'password') { inp.type = 'text'; eye.textContent = '🙈'; }
  else                        { inp.type = 'password'; eye.textContent = '👁'; }
}

function checkPassword() {
  const val = document.getElementById('pw-input').value;
  if(val !== DELETE_PW) {
    const err = document.getElementById('pw-err');
    err.style.display = 'block';
    // Retrigger shake animation
    err.style.animation = 'none';
    err.offsetHeight; // reflow
    err.style.animation = '';
    document.getElementById('pw-input').value = '';
    return;
  }
  // Correct password — delete the event
  document.getElementById('del-password').classList.remove('on');
  document.body.style.overflow = '';

  const idx = EV.findIndex(x => x.id === _deleteId);
  const deletedName = idx >= 0 ? EV[idx].name : '';
  if(idx >= 0) EV.splice(idx, 1);

  // Rebuild panels
  document.getElementById('cal-grid').innerHTML = '';
  document.getElementById('tl-months').innerHTML = '';
  document.getElementById('tl-body').innerHTML = '<div class="tl-gl" id="tl-gl"></div>';
  document.getElementById('tl-legend').innerHTML = '';
  document.getElementById('tbl-body').innerHTML = '';
  buildCal(); buildTL(); buildTbl(); refreshLiveBar();

  // Update stat counter
  document.getElementById('stat-ev').textContent = EV.length;

  _deleteId = null;
  showToast('🗑 "' + (deletedName.length > 35 ? deletedName.substring(0,35)+'…' : deletedName) + '" silindi.');
}

function backToDetail() {
  document.getElementById('del-password').classList.remove('on');
  // Reopen detail modal
  if(_deleteId !== null) openM(_deleteId);
}


function fmtDT(v){return v?new Date(v).toLocaleString('tr-TR',{dateStyle:'medium',timeStyle:'short'}):'-';}
function statusLabel(s){return ({confirmed:'Doğrulandı',needs_review:'Kontrol Gerekli',candidate:'Aday',cancelled:'İptal',deprecated:'Arşiv'})[s]||s||'Bilinmiyor';}
function sourceLabel(s){return ({official_site:'Resmi Site',organizer:'Organizatör',association:'Birlik',venue:'Mekan',secondary_backup:'Yedek Kaynak'})[s]||'Kaynak';}
let aStatus='all';
function filterStatus(status,btn){document.querySelectorAll('.status-btn').forEach(b=>b.classList.remove('on'));btn.classList.add('on');aStatus=status;apply();}
function refreshLiveBar(){
 const confirmed=EV.filter(e=>e.status==='confirmed').length;
 const review=EV.filter(e=>e.status==='needs_review').length;
 const sources=new Set(EV.map(e=>sourceLabel(e.source_type))).size;
 const last=EV.map(e=>e.last_checked_at).filter(Boolean).sort().slice(-1)[0]||BUILD_META.generated_at;
 document.getElementById('live-last-sync').textContent=fmtDT(last);
 document.getElementById('live-confirmed').textContent=`${confirmed}/${EV.length}`;
 document.getElementById('live-review').textContent=review;
 document.getElementById('live-sources').textContent=sources;
 document.getElementById('stat-ev').textContent=EV.length;
 const countries=new Set(EV.map(e=>e.country)).size;
 const regions=new Set(EV.map(e=>e.region)).size;
 const months=new Set(EV.map(e=>getMonth(e.s))).size;
 const statBoxes=document.querySelectorAll('.stat-box .stat-n');
 if(statBoxes[1]) statBoxes[1].textContent=countries;
 if(statBoxes[2]) statBoxes[2].textContent=regions;
 if(statBoxes[3]) statBoxes[3].textContent=months;
}

/* ═══════════ INIT ═══════════ */
buildCal(); buildTL(); buildTbl(); refreshLiveBar();

// Show mobile add button on small screens
if(window.innerWidth < 768) {
  const mb = document.getElementById('btn-add-mobile');
  if(mb) mb.style.display = 'inline-flex';
}

// Escape closes form too
document.addEventListener('keydown', e => {
  if(e.key === 'Escape') { closeM(); closeAddForm(); }
});
</script>
